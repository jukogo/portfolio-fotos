---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: #020202;
        color: #f5f5f5;
      }
      header {
        padding: 2rem 1rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      header h1 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin: 0;
      }
      header p {
        margin: 0.5rem 0 0;
        color: #cccccc;
        font-size: 1rem;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem 2rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
      }
      .card {
        background: #111;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid #222;
        display: flex;
        flex-direction: column;
        min-height: 100%;
      }
      .card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
        transition: transform 0.25s ease-out;
      }
      .card:hover img {
        transform: scale(1.03);
      }
      .card-body {
        padding: 1rem 1.1rem 1.2rem;
      }
      .card-title {
        font-size: 1.3rem;
        margin: 0 0 0.4rem;
      }
      .card-desc {
        margin: 0;
        color: #b0b0b0;
        font-size: 0.95rem;
      }
      footer {
        text-align: center;
        padding: 1.5rem 1rem 2rem;
        font-size: 0.9rem;
        color: #9a9a9a;
        border-top: 1px solid #222;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>{title}</h1>
      <p>{description}</p>
    </header>
    <main>
      <section>
        <div class="grid">
          {sections.map((section) => (
            <a class="card" href={section.href}>
              <img src={section.cover} alt={section.name} loading="lazy" />
              <div class="card-body">
                <h2 class="card-title">{section.name}</h2>
                <p class="card-desc">{section.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
    <footer>
      <p>Portfolio fotográfico - Juan Carlos P.</p>
    </footer>
  </body>
</html>