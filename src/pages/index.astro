---
const title = "Portfolio fotográfico - Juan Carlos P.";
const description =
  "Selección de fotografías en blanco y negro, ciudades, gente, macro, naturaleza y nocturnas.";

// Usar la misma base que en el resto del sitio
const imgBase = "/portfolio-fotos/images";

const sections = [
  {
    id: "bw",
    name: "Blanco y negro",
    description: "Imágenes en blanco y negro con énfasis en textura, luz y contraste.",
    href: "/portfolio-fotos/bw",
    cover: `${imgBase}/BW/La_Mola_Menorca_01.jpg`,
  },
  {
    id: "ciudades",
    name: "Ciudades",
    description: "Paisajes urbanos, arquitectura y escenas de calle.",
    href: "/portfolio-fotos/ciudades",
    cover: `${imgBase}/Ciudades/Ciutat_de_les_Arts_Valencia.jpg`,
  },
  {
    id: "gente",
    name: "Gente",
    description: "Retratos, instantes cotidianos y escenas humanas.",
    href: "/portfolio-fotos/gente",
    cover: `${imgBase}/Gente/Valencia_01.jpg`,
  },
  {
    id: "macro",
    name: "Macro",
    description: "Detalles y texturas a muy corta distancia.",
    href: "/portfolio-fotos/macro",
    cover: `${imgBase}/Macro/Araña.jpg`,
  },
  {
    id: "naturaleza",
    name: "Naturaleza",
    description: "Paisajes, flora, fauna y escenas al aire libre.",
    href: "/portfolio-fotos/naturaleza",
    cover: `${imgBase}/Naturaleza/Menorca_01.jpg`,
  },
  {
    id: "nocturnas",
    name: "Nocturnas",
    description: "Fotografía nocturna, luces de ciudad y cielos oscuros.",
    href: "/portfolio-fotos/nocturnas",
    cover: `${imgBase}/Nocturnas/M81.jpg`,
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: #020202;
        color: #f5f5f5;
      }
      header {
        padding: 2.5rem 1rem 1rem;
        text-align: center;
      }
      header h1 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin: 0 0 0.5rem;
      }
      header p {
        margin: 0;
        color: #cccccc;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem 2.5rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
      }
      .card {
        background: #111;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid #222;
        display: flex;
        flex-direction: column;
        min-height: 100%;
      }
      .card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
        transition: transform 0.25s ease-out;
      }
      .card:hover img {
        transform: scale(1.03);
      }
      .card-body {
        padding: 1rem 1.1rem 1.2rem;
      }
      .card-title {
        font-size: 1.3rem;
        margin: 0 0 0.4rem;
      }
      .card-desc {
        margin: 0;
        color: #b0b0b0;
        font-size: 0.95rem;
      }
      footer {
        text-align: center;
        padding: 1.5rem 1rem 2rem;
        font-size: 0.9rem;
        color: #9a9a9a;
        border-top: 1px solid #222;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>{title}</h1>
      <p>{description}</p>
    </header>

    <main>
      <section>
        <div class="grid">
          {sections.map((section) => (
            <a class="card" href={section.href}>
              <img src={section.cover} alt={section.name} loading="lazy" />
              <div class="card-body">
                <h2 class="card-title">{section.name}</h2>
                <p class="card-desc">{section.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer>
      &copy; {new Date().getFullYear()} Juan Carlos P. · Portfolio fotográfico
    </footer>
  </body>
</html>