---
const title = "Nocturnas · Portfolio fotográfico - Juan Carlos P.";
const description = "Fotografía nocturna, luces de ciudad,cielos oscuros y espacio profundo.";
const imgBase = "/portfolio-fotos/images";

const nocturnasImages = [
  `${imgBase}/Nocturnas/HD279230.jpg`,
  `${imgBase}/Nocturnas/M81.jpg`,
];

const category = "Nocturnas";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: #020202;
        color: #f5f5f5;
      }
      header {
        padding: 1.5rem 1rem 0.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      header a {
        color: #f5f5f5;
        text-decoration: none;
        font-size: 0.9rem;
        opacity: 0.8;
      }
      header a:hover { opacity: 1; }
      header h1 {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        margin: 0.8rem 0 0.4rem;
      }
      header p {
        margin: 0;
        color: #cccccc;
      }
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 1rem 2.5rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
      }
      figure {
        margin: 0;
        border-radius: 10px;
        overflow: hidden;
        background: #111;
        cursor: pointer;
      }
      figure img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.25s ease-out;
      }
      figure:hover img {
        transform: scale(1.03);
      }
      /* Lightbox */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 50;
      }
      .lightbox.open {
        display: flex;
      }
      .lightbox img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
      }
      .lightbox-close {
        position: fixed;
        top: 1.2rem;
        right: 1.4rem;
        font-size: 2rem;
        color: #f5f5f5;
        cursor: pointer;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/portfolio-fotos/">← Volver al índice</a>
      <h1>{category}</h1>
      <p>{description}</p>
    </header>

    <main>
      <section class="grid" id="gallery">
        {images.map((src) => (
          <figure data-src={src}>
            <img src={src} alt={category} loading="lazy" />
          </figure>
        ))}
      </section>
    </main>

    <div class="lightbox" id="lightbox">
      <span class="lightbox-close" id="lightbox-close">&times;</span>
      <img id="lightbox-image" src="" alt={category} />
    </div>

    <script>
      const gallery = document.getElementById("gallery");
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");

      if (gallery && lightbox && lightboxImg && lightboxClose) {
        gallery.addEventListener("click", (event) => {
          const figure = event.target.closest("figure");
          if (!figure) return;
          const src = figure.getAttribute("data-src");
          if (!src) return;
          lightboxImg.src = src;
          lightbox.classList.add("open");
        });

        lightbox.addEventListener("click", (event) => {
          if (event.target === lightbox || event.target === lightboxClose) {
            lightbox.classList.remove("open");
            lightboxImg.src = "";
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            lightbox.classList.remove("open");
            lightboxImg.src = "";
          }
        });
      }
    </script>
  </body>
</html>